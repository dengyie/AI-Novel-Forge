{
  "name": "@ai-novel/server",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "ts-node-dev --transpile-only src/db/seed.ts"
  },
  "scripts": {
    "dev": "pnpm prisma:generate && pnpm prisma:migrate && ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"No lint configured for @ai-novel/server\"",
    "prisma": "prisma",
    "prisma:generate": "prisma generate --schema src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --name init --schema src/prisma/schema.prisma",
    "db:migrate": "pnpm prisma:migrate",
    "db:seed": "prisma db seed --schema src/prisma/schema.prisma",
    "db:studio": "prisma studio --schema src/prisma/schema.prisma"
  },
  "dependencies": {
    "@ai-novel/shared": "workspace:*",
    "@langchain/community": "^1.1.21",
    "@langchain/core": "^1.1.29",
    "@langchain/langgraph": "^1.2.0",
    "@langchain/openai": "^1.2.11",
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "langchain": "^1.2.28",
    "morgan": "^1.10.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.3.3",
    "prisma": "^7.4.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
