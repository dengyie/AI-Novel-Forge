generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum ChapterGenerationState {
  planned
  drafted
  reviewed
  repaired
  approved
  published
}

enum PipelineJobStatus {
  queued
  running
  succeeded
  failed
  cancelled
}

enum BeatStatus {
  planned
  completed
  skipped
}

enum FactCategory {
  world
  character
  timeline
  plot
  rule
}

enum RagOwnerType {
  novel
  chapter
  world
  character
  bible
  chapter_summary
  consistency_fact
  character_timeline
  world_library_item
  knowledge_document
  chat_message
}

enum RagJobType {
  upsert
  delete
  rebuild
}

enum RagJobStatus {
  queued
  running
  succeeded
  failed
  cancelled
}

enum KnowledgeDocumentStatus {
  enabled
  disabled
  archived
}

enum KnowledgeIndexStatus {
  idle
  queued
  running
  succeeded
  failed
}

enum KnowledgeBindingTargetType {
  novel
  world
}

enum BookAnalysisStatus {
  draft
  queued
  running
  succeeded
  failed
  cancelled
  archived
}

enum BookAnalysisSectionStatus {
  idle
  running
  succeeded
  failed
}

enum ImageSceneType {
  character
  novel_cover
  chapter_illustration
}

enum ProjectMode {
  ai_led
  co_pilot
  draft_mode
  auto_pipeline
}

enum NarrativePov {
  first_person
  third_person
  mixed
}

enum PacePreference {
  slow
  balanced
  fast
}

enum EmotionIntensity {
  low
  medium
  high
}

enum AIFreedom {
  low
  medium
  high
}

enum ProjectProgressStatus {
  not_started
  in_progress
  completed
  rework
  blocked
}

enum StorylineVersionStatus {
  draft
  active
  frozen
}

enum ChapterStatus {
  unplanned
  pending_generation
  generating
  pending_review
  needs_repair
  completed
}

enum PipelineRunMode {
  fast
  polish
}

enum PipelineRepairMode {
  detect_only
  light_repair
  heavy_repair
  continuity_only
  character_only
  ending_only
}

enum AgentRunStatus {
  queued
  running
  waiting_approval
  succeeded
  failed
  cancelled
}

enum AgentStepType {
  planning
  tool_call
  tool_result
  reasoning
  write
  approval
  answer
}

enum AgentStepStatus {
  pending
  running
  succeeded
  failed
  cancelled
}

enum AgentApprovalStatus {
  pending
  approved
  rejected
  expired
}

enum CreativeHubThreadStatus {
  idle
  busy
  interrupted
  error
}

enum StoryPlanLevel {
  book
  arc
  chapter
}

enum AuditType {
  continuity
  character
  plot
}

enum AuditIssueStatus {
  open
  resolved
  ignored
}

model Novel {
  id                String      @id @default(cuid())
  title             String
  description       String?
  status            String      @default("draft")
  writingMode       String      @default("original")
  projectMode       ProjectMode?
  narrativePov      NarrativePov?
  pacePreference    PacePreference?
  styleTone         String?
  emotionIntensity  EmotionIntensity?
  aiFreedom         AIFreedom?
  defaultChapterLength Int?
  projectStatus     ProjectProgressStatus? @default(not_started)
  storylineStatus   ProjectProgressStatus? @default(not_started)
  outlineStatus     ProjectProgressStatus? @default(not_started)
  resourceReadyScore Int?
  sourceNovelId     String?
  sourceKnowledgeDocumentId String?
  continuationBookAnalysisId String?
  continuationBookAnalysisSections String?
  outline           String?
  structuredOutline String?
  genreId           String?
  worldId           String?
  genre             NovelGenre? @relation(fields: [genreId], references: [id])
  world             World?      @relation(fields: [worldId], references: [id], onDelete: SetNull)
  sourceNovel       Novel?      @relation("NovelContinuation", fields: [sourceNovelId], references: [id], onDelete: SetNull)
  continuationNovels Novel[]    @relation("NovelContinuation")
  sourceKnowledgeDocument KnowledgeDocument? @relation("NovelKnowledgeContinuation", fields: [sourceKnowledgeDocumentId], references: [id], onDelete: SetNull)
  continuationBookAnalysis BookAnalysis? @relation("NovelContinuationBookAnalysis", fields: [continuationBookAnalysisId], references: [id], onDelete: SetNull)
  chapters          Chapter[]
  characters        Character[]
  characterTimelines CharacterTimeline[]
  bible             NovelBible?
  plotBeats         PlotBeat[]
  chapterSummaries  ChapterSummary[]
  facts             ConsistencyFact[]
  generationJobs    GenerationJob[]
  agentRuns          AgentRun[]
  creativeDecisions  CreativeDecision[]
  novelSnapshots     NovelSnapshot[]
  storylineVersions  StorylineVersion[]
  qualityReports     QualityReport[]
  storyStateSnapshots StoryStateSnapshot[]
  storyPlans         StoryPlan[]
  replanRuns         ReplanRun[]
  auditReports       AuditReport[]
  createdAt          DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([genreId])
  @@index([worldId])
  @@index([writingMode])
  @@index([sourceNovelId])
  @@index([sourceKnowledgeDocumentId])
  @@index([continuationBookAnalysisId])
}

model CreativeDecision {
  id          String   @id @default(cuid())
  novelId     String
  chapterId   String?
  category    String
  content     String
  importance  String   @default("normal")
  expiresAt   Int?
  sourceType  String?
  sourceRefId String?
  novel       Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([novelId, createdAt])
}

model NovelSnapshot {
  id           String   @id @default(cuid())
  novelId      String
  label        String?
  snapshotData String
  triggerType  String
  novel        Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([novelId, createdAt])
}

model Chapter {
  id              String                 @id @default(cuid())
  title           String
  content         String?                @default("")
  order           Int
  generationState ChapterGenerationState @default(planned)
  chapterStatus   ChapterStatus?         @default(unplanned)
  targetWordCount Int?
  conflictLevel   Int?
  revealLevel     Int?
  mustAvoid       String?
  taskSheet       String?
  sceneCards      String?
  repairHistory   String?
  qualityScore    Int?
  continuityScore Int?
  characterScore  Int?
  pacingScore     Int?
  riskFlags       String?
  hook            String?
  expectation     String?
  novelId         String
  novel           Novel                  @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapterSummary  ChapterSummary?
  characterTimelines CharacterTimeline[]
  facts           ConsistencyFact[]
  qualityReports  QualityReport[]
  storyStateSnapshots StoryStateSnapshot[]
  storyPlans      StoryPlan[]
  replanRuns      ReplanRun[]
  auditReports    AuditReport[]
  foreshadowSetupStates ForeshadowState[] @relation("ForeshadowSetupChapter")
  foreshadowPayoffStates ForeshadowState[] @relation("ForeshadowPayoffChapter")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([novelId, order])
}

model Character {
  id              String   @id @default(cuid())
  name            String
  role            String
  personality     String?
  background      String?
  development     String?
  currentState    String?
  currentGoal     String?
  lastEvolvedAt   DateTime?
  novelId         String
  novel           Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  baseCharacterId String?
  timelines       CharacterTimeline[]
  stateEntries    CharacterState[]
  outgoingRelations RelationState[] @relation("RelationStateSource")
  incomingRelations RelationState[] @relation("RelationStateTarget")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([novelId])
  @@index([baseCharacterId])
}

model CharacterTimeline {
  id          String    @id @default(cuid())
  novelId     String
  characterId String
  chapterId   String?
  chapterOrder Int?
  title       String
  content     String
  source      String    @default("auto")
  novel       Novel     @relation(fields: [novelId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  chapter     Chapter?  @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([novelId, characterId])
  @@index([characterId, chapterOrder])
  @@index([chapterId])
}

model BaseCharacter {
  id          String   @id @default(cuid())
  name        String
  role        String
  personality String
  background  String
  development String
  appearance  String?
  weaknesses  String?
  interests   String?
  keyEvents   String?
  tags        String   @default("")
  category    String
  imageTasks  ImageGenerationTask[]
  imageAssets ImageAsset[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ImageGenerationTask {
  id              String            @id @default(cuid())
  sceneType       ImageSceneType    @default(character)
  baseCharacterId String?
  provider        String
  model           String
  prompt          String
  negativePrompt  String?
  stylePreset     String?
  size            String            @default("1024x1024")
  imageCount      Int               @default(1)
  seed            Int?
  status          PipelineJobStatus @default(queued)
  progress        Float             @default(0)
  retryCount      Int               @default(0)
  maxRetries      Int               @default(2)
  heartbeatAt     DateTime?
  currentStage    String?
  currentItemKey  String?
  currentItemLabel String?
  cancelRequestedAt DateTime?
  error           String?
  startedAt       DateTime?
  finishedAt      DateTime?
  baseCharacter   BaseCharacter?    @relation(fields: [baseCharacterId], references: [id], onDelete: Cascade)
  assets          ImageAsset[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([sceneType, status])
  @@index([baseCharacterId, createdAt])
}

model ImageAsset {
  id              String            @id @default(cuid())
  taskId          String
  sceneType       ImageSceneType    @default(character)
  baseCharacterId String?
  provider        String
  model           String
  url             String
  mimeType        String?
  width           Int?
  height          Int?
  seed            Int?
  prompt          String?
  isPrimary       Boolean           @default(false)
  sortOrder       Int               @default(0)
  metadata        String?
  task            ImageGenerationTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  baseCharacter   BaseCharacter?    @relation(fields: [baseCharacterId], references: [id], onDelete: Cascade)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([taskId])
  @@index([sceneType, createdAt])
  @@index([baseCharacterId, isPrimary, createdAt])
}

model NovelGenre {
  id          String       @id @default(cuid())
  name        String
  description String?
  template    String?
  parentId    String?
  parent      NovelGenre?  @relation("GenreChildren", fields: [parentId], references: [id])
  children    NovelGenre[] @relation("GenreChildren")
  novels      Novel[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([parentId])
}

model World {
  id                 String                @id @default(cuid())
  name               String
  description        String?
  worldType          String?
  templateKey        String?
  axioms             String?
  background         String?
  geography          String?
  cultures           String?
  magicSystem        String?
  politics           String?
  races              String?
  religions          String?
  technology         String?
  conflicts          String?
  history            String?
  economy            String?
  factions           String?
  status             String                @default("draft")
  version            Int                   @default(1)
  selectedDimensions String?
  selectedElements   String?
  layerStates        String?
  consistencyReport  String?
  overviewSummary    String?
  novels             Novel[]
  snapshots          WorldSnapshot[]
  deepeningQA        WorldDeepeningQA[]
  consistencyIssues  WorldConsistencyIssue[]
  libraryItems       WorldPropertyLibrary[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
}

model WorldPropertyLibrary {
  id            String  @id @default(cuid())
  name          String
  description   String?
  category      String
  worldType     String?
  usageCount    Int     @default(0)
  sourceWorldId String?
  sourceWorld   World?  @relation(fields: [sourceWorldId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([sourceWorldId])
}

model WorldSnapshot {
  id        String   @id @default(cuid())
  worldId   String
  label     String?
  data      String
  world     World    @relation(fields: [worldId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([worldId, createdAt])
}

model WorldDeepeningQA {
  id               String   @id @default(cuid())
  worldId          String
  priority         String   @default("recommended")
  question         String
  targetLayer      String?
  targetField      String?
  answer           String?
  integratedSummary String?
  status           String   @default("pending")
  world            World    @relation(fields: [worldId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([worldId, status])
}

model WorldConsistencyIssue {
  id          String   @id @default(cuid())
  worldId     String
  severity    String
  code        String
  message     String
  detail      String?
  source      String   @default("rule")
  status      String   @default("open")
  targetField String?
  world       World    @relation(fields: [worldId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([worldId, status])
  @@index([worldId, severity])
}

model WritingFormula {
  id                 String   @id @default(cuid())
  name               String
  sourceText         String?
  content            String?
  genre              String?
  style              String?
  toneVoice          String?
  structure          String?
  pacing             String?
  paragraphPattern   String?
  sentenceStructure  String?
  vocabularyLevel    String?
  rhetoricalDevices  String?
  narrativeMode      String?
  perspectivePoint   String?
  characterVoice     String?
  themes             String?
  motifs             String?
  emotionalTone      String?
  uniqueFeatures     String?
  formulaDescription String?
  formulaSteps       String?
  applicationTips    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model TitleLibrary {
  id          String   @id @default(cuid())
  title       String
  description String?
  clickRate   Float?
  keywords    String?
  genreId     String?
  usedCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model APIKey {
  id        String   @id @default(cuid())
  provider  String
  key       String
  model     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider])
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ModelRouteConfig {
  id          String  @id @default(cuid())
  taskType    String  @unique
  provider    String
  model       String
  temperature Float   @default(0.7)
  maxTokens   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NovelBible {
  id             String   @id @default(cuid())
  novelId        String   @unique
  coreSetting    String?
  forbiddenRules String?
  mainPromise    String?
  characterArcs  String?
  worldRules     String?
  rawContent     String?
  novel          Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PlotBeat {
  id           String     @id @default(cuid())
  novelId      String
  chapterOrder Int?
  beatType     String
  title        String
  content      String
  status       BeatStatus @default(planned)
  metadata     String?
  novel        Novel      @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([novelId])
  @@index([novelId, chapterOrder])
}

model ChapterSummary {
  id              String   @id @default(cuid())
  novelId         String
  chapterId       String   @unique
  summary         String
  keyEvents       String?
  characterStates String?
  hook            String?
  novel           Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter         Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([novelId])
}

model ConsistencyFact {
  id        String       @id @default(cuid())
  novelId   String
  chapterId String?
  category  FactCategory @default(plot)
  content   String
  source    String?
  novel     Novel        @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter   Chapter?     @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([novelId])
  @@index([chapterId])
  @@index([novelId, category])
}

model GenerationJob {
  id             String            @id @default(cuid())
  novelId        String
  startOrder     Int
  endOrder       Int
  runMode        PipelineRunMode?  @default(fast)
  autoReview     Boolean           @default(true)
  autoRepair     Boolean           @default(true)
  skipCompleted  Boolean           @default(true)
  qualityThreshold Int?
  repairMode     PipelineRepairMode? @default(light_repair)
  status         PipelineJobStatus @default(queued)
  progress       Float             @default(0)
  completedCount Int               @default(0)
  totalCount     Int               @default(0)
  retryCount     Int               @default(0)
  maxRetries     Int               @default(2)
  heartbeatAt    DateTime?
  currentStage   String?
  currentItemKey String?
  currentItemLabel String?
  cancelRequestedAt DateTime?
  error          String?
  lastErrorType  String?
  payload        String?
  startedAt      DateTime?
  finishedAt     DateTime?
  novel          Novel             @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([novelId])
  @@index([novelId, status])
}

model AgentRun {
  id           String         @id @default(cuid())
  novelId      String?
  chapterId    String?
  sessionId    String
  goal         String
  entryAgent   String
  status       AgentRunStatus @default(queued)
  currentStep  String?
  currentAgent String?
  error        String?
  startedAt    DateTime?
  finishedAt   DateTime?
  metadataJson String?
  novel        Novel?         @relation(fields: [novelId], references: [id], onDelete: SetNull)
  steps        AgentStep[]
  approvals    AgentApproval[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status, updatedAt])
  @@index([novelId, createdAt])
  @@index([novelId, chapterId, createdAt])
  @@index([sessionId, createdAt])
}

model AgentStep {
  id             String          @id @default(cuid())
  runId          String
  seq            Int
  agentName      String
  stepType       AgentStepType
  status         AgentStepStatus @default(succeeded)
  parentStepId   String?
  idempotencyKey String?
  inputJson      String?
  outputJson     String?
  error          String?
  errorCode      String?
  provider       String?
  model          String?
  tokenUsageJson String?
  costUsd        Float?
  durationMs     Int?
  run            AgentRun        @relation(fields: [runId], references: [id], onDelete: Cascade)
  approvals      AgentApproval[]
  createdAt      DateTime        @default(now())

  @@unique([runId, seq])
  @@index([runId, idempotencyKey])
  @@index([runId, parentStepId])
}

model AgentApproval {
  id           String             @id @default(cuid())
  runId        String
  stepId       String?
  approvalType String
  targetType   String
  targetId     String
  diffSummary  String
  status       AgentApprovalStatus @default(pending)
  expiresAt    DateTime?
  decisionNote String?
  decider      String?
  decidedAt    DateTime?
  payloadJson  String?
  run          AgentRun           @relation(fields: [runId], references: [id], onDelete: Cascade)
  step         AgentStep?         @relation(fields: [stepId], references: [id], onDelete: SetNull)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([runId, status])
  @@index([stepId])
  @@index([status, expiresAt])
}

model CreativeHubThread {
  id               String                  @id @default(cuid())
  title            String                  @default("新对话")
  archived         Boolean                 @default(false)
  status           CreativeHubThreadStatus @default(idle)
  latestRunId      String?
  latestError      String?
  resourceBindingsJson String?
  metadataJson     String?
  checkpoints      CreativeHubCheckpoint[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([archived, updatedAt])
  @@index([status, updatedAt])
}

model CreativeHubCheckpoint {
  id                String            @id @default(cuid())
  threadId          String
  checkpointId      String
  parentCheckpointId String?
  runId             String?
  messageCount      Int               @default(0)
  preview           String?
  messagesJson      String
  interruptsJson    String?
  metadataJson      String?
  thread            CreativeHubThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  createdAt         DateTime          @default(now())

  @@unique([threadId, checkpointId])
  @@index([threadId, createdAt])
}

model StorylineVersion {
  id          String                @id @default(cuid())
  novelId     String
  version     Int
  status      StorylineVersionStatus @default(draft)
  content     String
  diffSummary String?
  novel       Novel                 @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([novelId, version])
  @@index([novelId, status, createdAt])
}

model QualityReport {
  id         String   @id @default(cuid())
  novelId    String
  chapterId  String?
  coherence  Int
  repetition Int
  pacing     Int
  voice      Int
  engagement Int
  overall    Int
  issues     String?
  novel      Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter    Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([novelId])
  @@index([chapterId])
  @@index([novelId, createdAt])
}

model StoryStateSnapshot {
  id             String   @id @default(cuid())
  novelId        String
  sourceChapterId String?
  summary        String?
  rawStateJson   String?
  novel          Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  sourceChapter  Chapter? @relation(fields: [sourceChapterId], references: [id], onDelete: SetNull)
  characterStates CharacterState[]
  relationStates RelationState[]
  informationStates InformationState[]
  foreshadowStates ForeshadowState[]
  storyPlans     StoryPlan[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([novelId, sourceChapterId])
  @@index([novelId, createdAt])
  @@index([sourceChapterId])
}

model CharacterState {
  id             String   @id @default(cuid())
  snapshotId     String
  characterId    String
  currentGoal    String?
  emotion        String?
  stressLevel    Int?
  secretExposure String?
  knownFactsJson String?
  misbeliefsJson String?
  summary        String?
  snapshot       StoryStateSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  character      Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([snapshotId, characterId])
  @@index([characterId, createdAt])
}

model RelationState {
  id                String   @id @default(cuid())
  snapshotId        String
  sourceCharacterId String
  targetCharacterId String
  trustScore        Int?
  intimacyScore     Int?
  conflictScore     Int?
  dependencyScore   Int?
  summary           String?
  snapshot          StoryStateSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  sourceCharacter   Character @relation("RelationStateSource", fields: [sourceCharacterId], references: [id], onDelete: Cascade)
  targetCharacter   Character @relation("RelationStateTarget", fields: [targetCharacterId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([snapshotId, sourceCharacterId, targetCharacterId])
  @@index([sourceCharacterId, targetCharacterId])
}

model InformationState {
  id          String   @id @default(cuid())
  snapshotId  String
  holderType  String
  holderRefId String?
  fact        String
  status      String
  summary     String?
  snapshot    StoryStateSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([snapshotId, holderType])
}

model ForeshadowState {
  id             String   @id @default(cuid())
  snapshotId     String
  title          String
  summary        String?
  status         String
  setupChapterId String?
  payoffChapterId String?
  snapshot       StoryStateSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  setupChapter   Chapter? @relation("ForeshadowSetupChapter", fields: [setupChapterId], references: [id], onDelete: SetNull)
  payoffChapter  Chapter? @relation("ForeshadowPayoffChapter", fields: [payoffChapterId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([snapshotId, status])
  @@index([setupChapterId])
  @@index([payoffChapterId])
}

model StoryPlan {
  id                   String   @id @default(cuid())
  novelId              String
  chapterId            String?
  parentId             String?
  sourceStateSnapshotId String?
  level                StoryPlanLevel
  title                String
  objective            String
  participantsJson     String?
  revealsJson          String?
  riskNotesJson        String?
  hookTarget           String?
  status               String   @default("draft")
  externalRef          String?
  rawPlanJson          String?
  novel                Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter              Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  parent               StoryPlan? @relation("StoryPlanHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children             StoryPlan[] @relation("StoryPlanHierarchy")
  sourceStateSnapshot  StoryStateSnapshot? @relation(fields: [sourceStateSnapshotId], references: [id], onDelete: SetNull)
  scenes               ChapterPlanScene[]
  replanRuns           ReplanRun[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([novelId, level, createdAt])
  @@index([chapterId, createdAt])
  @@index([externalRef])
  @@index([sourceStateSnapshotId])
}

model ChapterPlanScene {
  id          String   @id @default(cuid())
  planId       String
  sortOrder    Int
  title        String
  objective    String?
  conflict     String?
  reveal       String?
  emotionBeat  String?
  plan         StoryPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([planId, sortOrder])
}

model ReplanRun {
  id           String   @id @default(cuid())
  novelId      String
  chapterId    String?
  sourcePlanId String?
  triggerType  String
  reason       String
  outputSummary String?
  novel        Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter      Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  sourcePlan   StoryPlan? @relation(fields: [sourcePlanId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([novelId, createdAt])
  @@index([chapterId, createdAt])
}

model AuditReport {
  id             String   @id @default(cuid())
  novelId        String
  chapterId      String
  auditType      AuditType
  overallScore   Int?
  summary        String?
  legacyScoreJson String?
  novel          Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapter        Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  issues         AuditIssue[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([novelId, chapterId, auditType, createdAt])
  @@index([chapterId, createdAt])
}

model AuditIssue {
  id            String   @id @default(cuid())
  reportId      String
  auditType     AuditType
  severity      String
  code          String
  description   String
  evidence      String
  fixSuggestion String
  status        AuditIssueStatus @default(open)
  report        AuditReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([reportId, status])
  @@index([auditType, severity])
}

model KnowledgeDocument {
  id                     String                   @id @default(cuid())
  title                  String
  fileName               String
  status                 KnowledgeDocumentStatus  @default(enabled)
  activeVersionId        String?
  activeVersionNumber    Int                      @default(0)
  latestIndexStatus      KnowledgeIndexStatus     @default(idle)
  lastIndexedAt          DateTime?
  activeVersion          KnowledgeDocumentVersion? @relation("KnowledgeDocumentActiveVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)
  versions               KnowledgeDocumentVersion[] @relation("KnowledgeDocumentVersions")
  bindings               KnowledgeBinding[]
  bookAnalyses           BookAnalysis[]
  publishedFromAnalyses  BookAnalysis[]           @relation("BookAnalysisPublishedDocument")
  continuationNovels     Novel[]                  @relation("NovelKnowledgeContinuation")
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  @@index([status, updatedAt])
  @@index([title])
}

model KnowledgeDocumentVersion {
  id                 String               @id @default(cuid())
  documentId         String
  versionNumber      Int
  content            String
  contentHash        String
  charCount          Int
  document           KnowledgeDocument    @relation("KnowledgeDocumentVersions", fields: [documentId], references: [id], onDelete: Cascade)
  activeForDocuments KnowledgeDocument[]  @relation("KnowledgeDocumentActiveVersion")
  bookAnalyses       BookAnalysis[]
  createdAt          DateTime             @default(now())

  @@unique([documentId, versionNumber])
  @@index([documentId, createdAt])
  @@index([contentHash])
}

model KnowledgeBinding {
  id         String                     @id @default(cuid())
  targetType KnowledgeBindingTargetType
  targetId   String
  documentId String
  document   KnowledgeDocument          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime                   @default(now())

  @@unique([targetType, targetId, documentId])
  @@index([targetType, targetId])
  @@index([documentId])
}

model BookAnalysis {
  id                          String             @id @default(cuid())
  documentId                  String
  documentVersionId           String
  title                       String
  status                      BookAnalysisStatus @default(queued)
  summary                     String?
  provider                    String?
  model                       String?
  temperature                 Float?
  maxTokens                   Int?
  progress                    Float              @default(0)
  heartbeatAt                 DateTime?
  currentStage                String?
  currentItemKey              String?
  currentItemLabel            String?
  cancelRequestedAt           DateTime?
  attemptCount                Int                @default(0)
  maxAttempts                 Int                @default(1)
  lastError                   String?
  lastRunAt                   DateTime?
  publishedDocumentId         String?
  document                    KnowledgeDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentVersion             KnowledgeDocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: NoAction)
  publishedDocument           KnowledgeDocument?  @relation("BookAnalysisPublishedDocument", fields: [publishedDocumentId], references: [id], onDelete: SetNull)
  continuationNovels          Novel[]             @relation("NovelContinuationBookAnalysis")
  sections                    BookAnalysisSection[]
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt

  @@index([documentId, status])
  @@index([documentVersionId])
  @@index([status, updatedAt])
}

model BookAnalysisSection {
  id                 String                    @id @default(cuid())
  analysisId         String
  sectionKey         String
  title              String
  status             BookAnalysisSectionStatus @default(idle)
  aiContent          String?
  editedContent      String?
  notes              String?
  structuredDataJson String?
  evidenceJson       String?
  frozen             Boolean                   @default(false)
  sortOrder          Int
  analysis           BookAnalysis              @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  updatedAt          DateTime                  @updatedAt

  @@unique([analysisId, sectionKey])
  @@index([analysisId, sortOrder])
}

model KnowledgeChunk {
  id            String       @id @default(cuid())
  tenantId      String       @default("default")
  ownerType     RagOwnerType
  ownerId       String
  novelId       String?
  worldId       String?
  title         String?
  chunkText     String
  chunkHash     String
  chunkOrder    Int
  tokenEstimate Int          @default(0)
  language      String       @default("zh")
  metadataJson  String?
  embedProvider String
  embedModel    String
  embedVersion  Int          @default(1)
  indexedAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([tenantId, ownerType, ownerId])
  @@index([tenantId, novelId])
  @@index([tenantId, worldId])
  @@index([chunkHash])
}

model RagIndexJob {
  id          String       @id @default(cuid())
  tenantId    String       @default("default")
  jobType     RagJobType
  ownerType   RagOwnerType
  ownerId     String
  status      RagJobStatus @default(queued)
  attempts    Int          @default(0)
  maxAttempts Int          @default(5)
  runAfter    DateTime     @default(now())
  payloadJson String?
  lastError   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status, runAfter])
  @@index([tenantId, ownerType, ownerId])
}
