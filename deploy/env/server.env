PORT=3000
# 局域网访问：HOST=0.0.0.0 且 ALLOW_LAN=true
HOST=0.0.0.0
ALLOW_LAN=true
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
# 默认使用 SQLite；如需 PostgreSQL，取消下一行注释并填写连接串。
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/ai_novel
API_JSON_LIMIT=20mb
# 每本小说保留的自动版本快照数量；手动保存的快照不受这个数量限制。
NOVEL_SNAPSHOT_RETENTION_COUNT=10

# 图片资产存储：默认使用 beta 本地文件存储。仅在显式选择 s3/minio 时启用 MinIO/S3。
# IMAGE_STORAGE_DRIVER=local
# IMAGE_STORAGE_ROOT=storage/generated-images
# IMAGE_STORAGE_DRIVER=minio
# IMAGE_STORAGE_S3_ENDPOINT=http://127.0.0.1:9000
# IMAGE_STORAGE_S3_REGION=us-east-1
# IMAGE_STORAGE_S3_BUCKET=ai-novel-images
# IMAGE_STORAGE_S3_ACCESS_KEY_ID=
# IMAGE_STORAGE_S3_SECRET_ACCESS_KEY=
# IMAGE_STORAGE_S3_FORCE_PATH_STYLE=true
# 图片生成接口最长等待时间（毫秒），默认 300000。
# IMAGE_GENERATION_HTTP_TIMEOUT_MS=300000

# ======== 以下所有 LLM 槽位统一走 CPA 代理 https://cpa.mangoq.ccwu.cc/v1 ========
# CPA key: sk-cpa-3e02334c56f431a623e9f9d7c36f29a3a262c32793908a09

OPENAI_API_KEY=sk-cpa-3e02334c56f431a623e9f9d7c36f29a3a262c32793908a09
OPENAI_BASE_URL=https://cpa.mangoq.ccwu.cc/v1
OPENAI_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

DEEPSEEK_API_KEY=sk-cpa-3e02334c56f431a623e9f9d7c36f29a3a262c32793908a09
DEEPSEEK_BASE_URL=https://cpa.mangoq.ccwu.cc/v1
DEEPSEEK_MODEL=deepseek-v4-flash

ANTHROPIC_API_KEY=sk-cpa-3e02334c56f431a623e9f9d7c36f29a3a262c32793908a09
ANTHROPIC_BASE_URL=https://cpa.mangoq.ccwu.cc/v1
ANTHROPIC_MODEL=claude-opus-4-6

GLM_API_KEY=sk-cpa-3e02334c56f431a623e9f9d7c36f29a3a262c32793908a09
GLM_BASE_URL=https://cpa.mangoq.ccwu.cc/v1
GLM_MODEL=glm-5.2

GEMINI_API_KEY=sk-cpa-3e02334c56f431a623e9f9d7c36f29a3a262c32793908a09
GEMINI_BASE_URL=https://cpa.mangoq.ccwu.cc/v1
GEMINI_MODEL=gemini-3.1-pro

# 以下渠道未启用（留空）
SILICONFLOW_API_KEY=
XAI_API_KEY=
KIMI_API_KEY=
QWEN_API_KEY=

# RAG / Vector
RAG_ENABLED=false
RAG_VERBOSE_LOG=false
RAG_DEFAULT_TENANT=default
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_VERSION=1
EMBEDDING_BATCH_SIZE=64
# Local Qdrant:
QDRANT_URL=http://127.0.0.1:6333
# Qdrant Cloud example:
# QDRANT_URL=https://your-cluster.us-west-2-0.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=ai_novel_chunks_v1
QDRANT_TIMEOUT_MS=120000
QDRANT_UPSERT_MAX_BYTES=3145728
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_VECTOR_CANDIDATES=40
RAG_KEYWORD_CANDIDATES=40
RAG_FINAL_TOP_K=8
RAG_WORKER_POLL_MS=2500
RAG_WORKER_MAX_ATTEMPTS=5
RAG_WORKER_RETRY_BASE_MS=5000
RAG_EMBEDDING_TIMEOUT_MS=30000
RAG_EMBEDDING_MAX_RETRIES=2
RAG_EMBEDDING_RETRY_BASE_MS=500
RAG_HTTP_TIMEOUT_MS=30000

# Book analysis
BOOK_ANALYSIS_MAX_CONCURRENT_TASKS=2
BOOK_ANALYSIS_NOTES_CONCURRENCY=2
BOOK_ANALYSIS_SECTION_CONCURRENCY=2
BOOK_ANALYSIS_CACHE_SEGMENT_VERSION=1
