node_modules/
dist/
.turbo/
.DS_Store
# macOS AppleDouble resource-fork metadata (._*) created when files cross macOS <-> Linux via sync disks/zip/tar.
# These pollute the tree (几百个 ._foo 文件) and would otherwise show as untracked git noise.
._*
**/._*

.env
.env.local
dev.db
client/.env
client/.env.local
server/.env
server/.env.local
server/dev.db
server/dev.db-shm
server/dev.db-wal
server/tmp_*.js
# server/tmp 是指向 /tmp/mnt/ainovel/tmp 的 symlink（运行时 HOT 区），整目录 ignore，
# 避免 git reset/pull 把 symlink 还原成普通目录（已发生多次）。
# 历史遗留的 db-backups/migration-history 等 tracked 文件已在同次提交从索引移除。
server/tmp/
server/tmp/**/*.db
server/tmp/**/*.db*
server/tmp/**/*.db-*
server/tmp/**/*.sqlite
server/tmp/**/*.sqlite*
server/tmp/**/*.sqlite-*
server/storage/
server/src/prisma/dev.db
server/src/prisma/dev.db-journal
.history/
.histyory/
.logs/
.tmp/
.codegraph/
.trae/
server/.tmp/
desktop/build/
desktop/runtime-migration-smoke/
server/prisma-diff-migrations-to-schema.sql

# AI tool artifacts
.claude/plan/
.claude/memory/
.spec-workflow/
.codex-backups/
.cursor/

# Playwright MCP debug artifacts
.playwright-mcp/
console-errors
current-page
network-requests
page-*.png
